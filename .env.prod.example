# Прод-переменные для docker-compose.prod.yml.
# Скопируйте в .env.prod и подставьте свои значения (deploy-vps.sh делает это сам).

# PostgreSQL
POSTGRES_USER=capi
POSTGRES_PASSWORD=укажите-надёжный-пароль
POSTGRES_DB=capi

# Секреты (сгенерируйте: openssl rand -hex 32)
JWT_SECRET=замените-на-случайную-строку
ENCRYPTION_KEY=замените-на-случайную-строку-32-байта

# Публичный домен (совпадает с доменом в apps/web/Caddyfile).
# Всё на одном origin через Caddy, поэтому оба значения — один и тот же https-адрес.
WEB_ORIGIN=https://capi.garden
PUBLIC_API_URL=https://capi.garden

# Версия Meta Graph API
META_GRAPH_API_VERSION=v25.0
