# Прод-переменные для docker-compose.prod.yml.
# Скопируйте в .env.prod и подставьте свои значения.

# PostgreSQL
POSTGRES_USER=capi
POSTGRES_PASSWORD=укажите-надёжный-пароль
POSTGRES_DB=capi

# Секреты (сгенерируйте: openssl rand -hex 32)
JWT_SECRET=замените-на-случайную-строку
ENCRYPTION_KEY=замените-на-случайную-строку-32-байта

# Публичный адрес фронта (для CORS/редиректов после OAuth)
WEB_ORIGIN=https://app.yourdomain.com

# Публичный адрес API — используется в вебхук-URL и OAuth redirect_uri.
# Если фронт и API за одним доменом через nginx — это тот же домен.
PUBLIC_API_URL=https://app.yourdomain.com

# Порт, на котором nginx (фронт+прокси) слушает на хосте
WEB_PORT=80

# Версия Meta Graph API
META_GRAPH_API_VERSION=v25.0
