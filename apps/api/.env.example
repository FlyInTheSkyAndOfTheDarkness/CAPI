# PostgreSQL (docker compose up -d поднимает базу с этими реквизитами)
DATABASE_URL=postgresql://capi:capi@localhost:5432/capi

# Redis для очередей BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production

# Ключ шифрования секретов в БД (токены CRM и пикселей). Задайте случайную строку
# (например: openssl rand -hex 32). Если не задан — используется JWT_SECRET.
# ВАЖНО: при смене ключа ранее зашифрованные токены перестанут расшифровываться.
ENCRYPTION_KEY=change-me-32-bytes-random

# Порт API
PORT=3001

# Публичный URL API — используется в вебхук-URL для CRM и в OAuth redirect_uri.
# В проде: https://api.yourdomain.com. Для локальной разработки с реальными CRM
# используйте туннель (ngrok / cloudflared) и укажите его адрес здесь.
PUBLIC_API_URL=http://localhost:3001

# Origin фронтенда для CORS и редиректов после OAuth
WEB_ORIGIN=http://localhost:5173

# Версия Meta Graph API (Marketing API живёт ~год на версию — обновляйте).
# Можно переопределить на уровне направления через config.apiVersion.
META_GRAPH_API_VERSION=v25.0
